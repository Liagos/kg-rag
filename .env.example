# ============================================================
# KG-RAG — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---------------------------------------------------------------------------
# Dataset
# ---------------------------------------------------------------------------
# Path to your Jira tickets JSON file (relative to project root)
json_file=data/raw/support_tickets_sample.json

# ---------------------------------------------------------------------------
# OpenAI (required)
# ---------------------------------------------------------------------------
OPEN_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Anthropic (optional — only needed if using Claude models)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# ChromaDB
# ---------------------------------------------------------------------------
CHROMA_HOST=chromadb       # use 'localhost' for local dev without Docker
CHROMA_PORT=8000

# ---------------------------------------------------------------------------
# Neo4j
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687    # use bolt://localhost:7687 for local dev
NEO4J_USER=neo4j
NEO4J_PASSWORD=yourpassword
NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# LLM settings
# ---------------------------------------------------------------------------
llm=gpt-4.1
embedding_model=text-embedding-3-large
